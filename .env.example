# PostgreSQL connection string used by the Go backend.
# The schema is created automatically on server start (auto-migration).
DATABASE_URL="postgres://moonbug:moonbug@localhost:5432/moonbug?sslmode=disable"

# JWT signing secret. Defaults to a dev secret if unset — override in production.
# JWT_SECRET="change-me-to-a-long-random-string"

# SMTP credentials for sending real passwordless OTP emails.
# When SMTP_HOST is unset, OTP codes are written to the server log instead
# (only in non-production) so the flow stays usable locally.
# SMTP_HOST=""
# SMTP_PORT="587"
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_FROM="noreply@moonbug.app"

# Set to "production" to disable the dev OTP code reveal and use Secure cookies.
APP_ENV="development"
